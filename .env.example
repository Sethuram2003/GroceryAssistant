# =====================================================
# Grocery Assistant - Environment Configuration Template
# =====================================================
# Copy this file to .env and fill in your values
# =====================================================

# =====================================================
# MYSQL DATABASE CONFIGURATION
# =====================================================
# The MySQL server credentials and database details

# Host where MySQL is running (localhost for local development)
MYSQL_HOST=localhost

# MySQL server port (default: 3306)
MYSQL_PORT=3306

# MySQL username with database access privileges
MYSQL_USER=grocery_user

# MySQL password for the user
MYSQL_PASSWORD=grocery_password

# Database name to use for the application
MYSQL_DATABASE=grocery_db

# =====================================================
# API SERVER CONFIGURATION
# =====================================================
# FastAPI and Uvicorn server settings

# Port on which the API will run (default: 8000)
API_PORT=8000

# Host to bind the API server (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# =====================================================
# APPLICATION ENVIRONMENT
# =====================================================
# General application settings

# Environment type: development, staging, or production
ENVIRONMENT=development

# Enable debug mode (set to False in production)
DEBUG=True

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =====================================================
# FEATURE FLAGS
# =====================================================
# Enable/disable specific features

# Enable chat/AI assistant feature
ENABLE_CHAT=true

# Enable CSV import functionality
ENABLE_CSV_IMPORT=true

# =====================================================
# AI/CHAT CONFIGURATION (Optional)
# =====================================================
# Only if you're using external AI services

# OpenAI API key (if using OpenAI for chat)
OPENAI_API_KEY=

# Chat model to use (e.g., gpt-3.5-turbo, gpt-4)
CHAT_MODEL=gpt-3.5-turbo

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
# Security and CORS settings

# Secret key for JWT tokens (generate a secure random key)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# =====================================================
# FILE UPLOAD CONFIGURATION
# =====================================================
# Settings for file uploads (CSV, etc.)

# Maximum file upload size in MB
MAX_UPLOAD_SIZE=50

# Allowed file types for upload (comma-separated)
ALLOWED_FILE_TYPES=.csv

# =====================================================
# CACHING CONFIGURATION
# =====================================================
# Optional: Cache settings for performance

# Enable caching
ENABLE_CACHE=true

# Cache TTL in seconds (0 = disabled)
CACHE_TTL=300

# =====================================================
# NOTES
# =====================================================
# - Never commit the actual .env file to version control
# - Use strong passwords for production databases
# - Change default values before deploying to production
# - Keep API keys and secrets secure
# - Use environment-specific .env files for different environments
